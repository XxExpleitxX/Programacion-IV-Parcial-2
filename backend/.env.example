# ──────────────────────────────────────────────────────────────────────────────
# Food Store — variables de entorno del backend (CE-03)
# Copiar a `.env` y completar los valores. NUNCA commitear el .env real.
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos (MySQL / XAMPP) ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=                       # vacío por defecto en XAMPP
DB_NAME=parcial_programacion4

# ── JWT ────────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-larga-de-minimo-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Cookie del access token ─────────────────────────────────────────────────────
COOKIE_NAME=access_token
COOKIE_MAX_AGE=1800
COOKIE_SECURE=False                # True en producción (HTTPS)
COOKIE_SAMESITE=lax

# ── MercadoPago (Checkout PRO) ───────────────────────────────────────────────────
# Credenciales de prueba: https://www.mercadopago.com.ar/developers
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_WEBHOOK_SECRET=                

# ── Cloudinary (gestión de imágenes) ─────────────────────────────────────────────
# Credenciales en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=mi-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WebSocket ─────────────────────────────────────────────────────────────────────
# El WS no requiere variables extra: la URL es /api/v1/pedidos/ws y se autentica
# con el mismo JWT (query param ?token=<access_token>).
